# Exemplo de variaveis para deploy na Vercel
# Configure estas chaves no painel da Vercel em:
# Project > Settings > Environment Variables

# Banco de dados MySQL
DB_HOST=seu-host-mysql
DB_PORT=3306
DB_USER=seu-usuario
DB_PASSWORD=sua-senha-forte
DB_NAME=seu-banco

# JWT
JWT_SECRET=troque_por_uma_chave_muito_longa_e_aleatoria
JWT_EXPIRES_IN=48h

# CORS
# Pode incluir mais de um dominio separado por virgula
CORS_ORIGIN=https://seu-projeto.vercel.app,https://www.seudominio.com.br

# Quando true, aceita automaticamente origem com mesmo host da requisicao
CORS_ALLOW_SAME_HOST=true

# Na Vercel, nao defina PORT manualmente
